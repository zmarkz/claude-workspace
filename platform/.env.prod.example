# Production environment variables
# Copy this file to .env.prod and fill in your production values

# EC2 Deployment
EC2_HOST=
EC2_USER=ubuntu
EC2_KEY_PATH=

# RDS Databases
RDS_MYSQL_HOST=
RDS_MYSQL_USER=
RDS_MYSQL_PASSWORD=

RDS_PG_HOST=
RDS_PG_USER=
RDS_PG_PASSWORD=

# Application
DOMAIN=
JWT_SECRET=

# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BRAVE_API_KEY=
KITE_API_KEY=
KITE_API_SECRET=

# AWS S3 (for backups)
AWS_S3_BUCKET=
