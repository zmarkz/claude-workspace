# Project environment template.
# Copy to .env and fill in. NEVER commit .env. NEVER put real secrets in this file.
# Customize this file per project — these are sensible defaults.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/project_db
DATABASE_URL_SYNC=postgresql+psycopg://user:password@localhost:5432/project_db

# -----------------------------------------------------------------------------
# Cache / queue
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Object storage (MinIO locally, S3 in prod)
# -----------------------------------------------------------------------------

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=local_dev_minio
S3_SECRET_KEY=local_dev_only
S3_BUCKET=project-documents

# -----------------------------------------------------------------------------
# AI / model adapter (only if AI is involved in the project)
# -----------------------------------------------------------------------------

# OLLAMA_HOST=http://localhost:11434
# EMBEDDING_MODEL=bge-m3
# COMPLETION_MODEL=qwen2.5:7b-instruct

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------

# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_local_random_value
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Observability (Phase 2+)
# -----------------------------------------------------------------------------

OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------

DEPLOYMENT_TARGET=local                  # local | shared-saas | customer-vpc | vercel | ...
