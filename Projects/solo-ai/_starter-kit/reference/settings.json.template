{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by ai-project-scaffold. See SECURITY_MODEL.md for the rationale behind each rule. The deny/ask/allow patterns are tuned for a production-grade project; relax with care.",

  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./apps/api/.env)",
      "Read(./apps/api/.env.*)",
      "Read(./apps/web/.env.local)",
      "Read(./apps/web/.env.*)",
      "Read(./infra/terraform/*.tfvars)",
      "Read(./infra/terraform/**/*.tfstate*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~/*)",
      "Bash(git push * --force*)",
      "Bash(git push --force *)",
      "Bash(git reset --hard HEAD~*)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm*)",
      "Bash(make clean)",
      "Bash(make down)",
      "Bash(alembic downgrade*)",
      "Bash(psql * -c \"DROP*)",
      "Bash(npm install -g*)",
      "Bash(pip install --break-system-packages*)",
      "Write(./.env)",
      "Write(./apps/*/Dockerfile*)",
      "Write(./infra/terraform/**)"
    ],
    "allow": [
      "Bash(make *)",
      "Bash(pnpm *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(alembic upgrade head)",
      "Bash(alembic revision*)",
      "Bash(docker compose *)",
      "Bash(docker logs *)",
      "Bash(docker ps*)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(mypy *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(gh pr *)",
      "Bash(rg *)",
      "Bash(fd *)"
    ]
  },

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },

  "teammateMode": "in-process",

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash scripts/session-start.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash scripts/guard-dangerous-command.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash scripts/check-secrets-staged.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash scripts/run-quality-checks.sh --changed-only" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "bash scripts/session-snapshot.sh" }
        ]
      }
    ]
  },

  "_notes": {
    "permissions": "deny/ask/allow patterns are the safety perimeter. Don't loosen without an ADR.",
    "agent_teams": "Experimental Claude Code feature, requires v2.1.32+. Subagent definitions in .claude/agents/ double as team teammate types — only their tools/model/body are honored when used as teammates (skills/mcpServers frontmatter ignored).",
    "teammateMode": "'in-process' works in any terminal. Switch to 'tmux' if you have iTerm2+tmux installed and want split panes.",
    "hooks": "Six hook stages wired: SessionStart prints context, PreToolUse blocks dangerous commands and secret-like writes, PostToolUse runs quality checks, PreCompact snapshots state.",
    "customize_per_project": "Add project-specific env vars (e.g. policy flags, region) to the env block, and add project-specific allow/deny patterns above."
  }
}
